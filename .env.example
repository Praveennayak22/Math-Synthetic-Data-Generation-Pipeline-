# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Post-Training Synthetic Data Pipeline - Environment Configuration Template
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file to .env and fill in your actual credentials
# IMPORTANT: Never commit .env to git (it's in .gitignore)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1. HuggingFace Dataset Access
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
HF_TOKEN="hf_xxxxxxxxxxxxxxxx"
# Get your token at: https://huggingface.co/settings/tokens
# Create a "Read" token for dataset access

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 2. Brain Model (Solution Generator) - For Code Pipeline
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TENSORSTUDIO_API_KEY="your_api_key_here"
# Used by: Code generation Stage 2 (Completion)
# Obtain from: TensorStudio dashboard or cluster admin

LLM_URL="https://api.tensorstudio.ai/sglang/v1/chat/completions"
# Or for internal cluster: http://soketlab-node049:30000/v1/chat/completions
# This endpoint generates solutions with reasoning

LLM_MODEL="openai/gpt-oss-120b"
# Model name for solution generation

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 3. Generator Model (Variant Creator) - For Code Pipeline
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
GEN_LLM_URL="http://soketlab-node049:30000/v1/chat/completions"
# For variant generation (high creativity)

GEN_LLM_MODEL="deepseek-v3.2"
# Model for creating diverse problem variants

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 4. Math Pipeline - Teacher Model
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
MODEL_API_KEY="your_api_key_here"
# Used by: BigMath pipeline (reasoning annotation)

MODEL_ENDPOINT="http://soketlab-node054:30000/v1/chat/completions"
# Endpoint for teacher model inference

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 5. Parallelism Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
GEN_PARALLEL_SEEDS=8
# Concurrent variant generations per batch
# Recommendation: Match your CPU cores (8-16 typical)

COMPLETION_PARALLEL=4
# Concurrent Brain model API calls
# Recommendation: Match API rate limit (4-8 typical)

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 6. Caching & Deduplication
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
HF_CACHE_DIR="./data/hf_cache"
# Where to cache downloaded datasets locally

DEDUP_THRESHOLD=0.85
# Semantic similarity threshold for deduplication (0-1)
# Higher = stricter deduplication

DEDUP_BATCH_SIZE=128
# Embedding batch size for semantic dedup

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 7. Safety & Validation
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SAFETY_SCAN_ENABLED=true
# Enable code safety scanning before execution

MIN_SOLUTION_LENGTH=50
# Reject solutions shorter than N characters

SANDBOX_TIMEOUT=10
# Max code execution time (seconds)

SANDBOX_MEMORY_MB=512
# Max memory per execution (MB)

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 8. Optional: Override config paths
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CONFIG_FILE="./math_generation/big_math_pipeline/config/config.yaml"
# OUTPUT_DIR="./output"
# LOG_DIR="./logs"
